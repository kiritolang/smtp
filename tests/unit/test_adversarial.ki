# Adversarial tests: hostile/garbage server behaviour must always surface as a typed SmtpError (never
# an uncaught native crash), and the client must never hang, mis-parse, or leak an injection.
var C = import("smtp.client")
var T = import("smtp.transport")
var E = import("smtp.errors")
var t = import("harness").Tester("adversarial")

# Assert fn() throws AND the exception is an SmtpError (or subclass) — i.e. no native error leaked.
var typed_throw = Function(name, fn):
    var threw = False
    var typed = False
    try:
        fn()
    catch E.SmtpError as e:
        threw = True
        typed = True
    catch as e:
        threw = True
        typed = False
    if not threw:
        discard t.check(name + " (expected a throw)", False)
    else:
        discard t.check(name + " (typed SmtpError)", typed)

var conn = Function(script):
    var c = C.SmtpClient(transport = T.FakeTransport(script), host = "mx", local_hostname = "cli")
    c.connect()
    return c

# A full transaction against a scripted server (used to probe many malformed replies uniformly).
var transact = Function(script):
    var c = C.SmtpClient(transport = T.FakeTransport(script), host = "mx", local_hostname = "cli")
    c.connect()
    c.ehlo()
    c.sendmail("a@x.com", ["b@y.com"], "Subject: x\r\n\r\nbody\r\n")
    c.quit()

# --- malformed status lines at the greeting ---
typed_throw("empty greeting line", Function(): return conn("\r\n"))
typed_throw("greeting too short", Function(): return conn("42\r\n"))
typed_throw("non-numeric greeting", Function(): return conn("abc def\r\n"))
typed_throw("bad separator greeting", Function(): return conn("220xhi\r\n"))
typed_throw("garbage bytes greeting", Function(): return conn("\x01\x02\x03 junk\r\n"))

# --- disconnects at every phase ---
typed_throw("disconnect before greeting", Function(): return conn(""))
typed_throw("disconnect after greeting", Function(): return transact("220 mx\r\n"))
typed_throw("disconnect after ehlo", Function(): return transact("220 mx\r\n250 mx\r\n"))
typed_throw("disconnect after mail", Function(): return transact("220 mx\r\n250 mx\r\n250 Ok\r\n"))
typed_throw("disconnect mid-DATA", Function(): return transact("220 mx\r\n250 mx\r\n250 Ok\r\n250 Ok\r\n354 go\r\n"))

# --- unexpected / hostile codes ---
typed_throw("greeting 421", Function(): return conn("421 service unavailable\r\n"))
typed_throw("ehlo then garbage", Function(): return transact("220 mx\r\nnot a reply at all\r\n"))
typed_throw("multiline code drift", Function(): return transact("220 mx\r\n250-a\r\n555 b\r\n"))
typed_throw("mail 5xx (sender refused)", Function(): return transact("220 mx\r\n250 mx\r\n550 denied\r\n"))
typed_throw("data 354 missing", Function(): return transact("220 mx\r\n250 mx\r\n250 Ok\r\n250 Ok\r\n503 bad seq\r\n"))
typed_throw("data content refused", Function(): return transact("220 mx\r\n250 mx\r\n250 Ok\r\n250 Ok\r\n354 go\r\n552 too big\r\n"))

# --- reader robustness: no crash, correct behaviour ---
# a very long single line is read without crashing
var c_long = conn("220 " + ("x" * 100000) + "\r\n")
t.check("100k greeting line read", len(c_long.greeting) > 99999)
# NUL bytes embedded in reply text are tolerated (part of the text)
t.check("greeting with NUL text ok", conn("220 mx\x00hello\r\n").greeting.find("mx") == 0)

# recv delivered one byte at a time still reassembles a full multi-line transaction
var script_ok = "220 mx\r\n250-mx\r\n250-SIZE 100\r\n250 8BITMIME\r\n250 Ok\r\n250 Ok\r\n354 go\r\n250 queued\r\n221 bye\r\n"
var c_chunk = C.SmtpClient(transport = T.FakeTransport(script_ok, 1), host = "mx", local_hostname = "cli")
c_chunk.connect()
c_chunk.ehlo()
t.check("chunked EHLO parsed", c_chunk.has_extension("SIZE") and c_chunk.has_extension("8BITMIME"))
var refused = c_chunk.sendmail("a@x.com", ["b@y.com"], "Subject: x\r\n\r\nbody\r\n")
t.eq("chunked transaction delivered", refused, {})

# --- huge multi-line EHLO (200 capabilities) does not choke ---
var caps = ["220 mx\r\n"]
caps.append("250-mx\r\n")
var i = 0
while i < 200:
    caps.append("250-X-CAP-" + String(i) + " param" + String(i) + "\r\n")
    i = i + 1
caps.append("250 HELP\r\n")
var c_big = conn("".join(caps))
c_big.ehlo()
t.check("200-line EHLO parsed", c_big.has_extension("X-CAP-199"))

# --- command injection stays blocked even with exotic control bytes ---
var c_inj = conn("220 mx\r\n250 mx\r\n")
c_inj.ehlo()
typed_throw("NUL in recipient", Function(): return c_inj.rcpt("a@b\x00evil"))
typed_throw("LF in sender", Function(): return c_inj.mail("a@b\ninject"))

t.done()
